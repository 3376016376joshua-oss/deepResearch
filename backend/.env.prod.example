# 生产环境变量模板
# 用法：复制为 backend/.env.prod，填入真值；切勿提交真值进 git。
#   cp backend/.env.prod.example backend/.env.prod
#   chmod 600 backend/.env.prod

# ==================== LLM & Embedding ====================
# 阿里云百炼 API Key（必填）。申请：https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-REPLACE_ME
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3-max

# OpenRouter（可选，多模型）
OPENROUTER_API_KEY=

# ==================== 文档解析 (DocMind) ====================
# 可选；不填则文档解析降级走本地 pdfplumber/python-docx
DOCMIND_ACCESS_KEY_ID=
DOCMIND_ACCESS_KEY_SECRET=

# ==================== 搜索 API ====================
# 博查搜索（必填）。申请：https://open.bochaai.com/
BOCHA_API_KEY=sk-REPLACE_ME
SERPER_API_KEY=

# ==================== 行业资讯 / 招投标（可选） ====================
JUHE_STOCK_API_KEY=
BID_APP_KEY=
BID_APP_SECRET=
BID_APP_CODE=

# ==================== 中间件（容器内联通使用 service 名） ====================
# 注意：在 docker-compose.prod.yml 中已用 environment 覆盖为 service 名。
# 这里写 service 名作为兜底，避免 .env 直接 source 时出错。
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=industry_assistant

MILVUS_HOST=milvus
MILVUS_PORT=19530

ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ==================== JWT 认证 ====================
# 生成强密钥：openssl rand -hex 32
JWT_SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== DeepScout / SFT 开关 ====================
# 生产/线上首发只用 DashScope，强制关闭本地 SFT 与 warm-up
DEEPSCOUT_USE_LOCAL_SFT=0
DEEPSCOUT_WARMUP=0

# ==================== CORS ====================
# 逗号分隔的允许来源；用 * 表示放开（仅调试用）
CORS_ORIGINS=https://app.example.com

# ==================== 其他 ====================
TIMEZONE=Asia/Shanghai
LOG_LEVEL=INFO
ENV=prod
